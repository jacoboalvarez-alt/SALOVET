<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MECAGOENELTFG.Views2.AsistentePageClient"
             Shell.NavBarIsVisible="False"
             BackgroundImageSource="fondo.png"
             Title="SALOVET AI">
    <Shell.TitleView>
        <Label Text="" IsVisible="False"/>
    </Shell.TitleView>

    <ContentPage.Resources>

        <DataTemplate x:Key="BotMessageTemplate">
            <Grid Margin="0,4,48,4">
                <Grid ColumnDefinitions="32,*" ColumnSpacing="8">
                    <Border Grid.Column="0"
                         BackgroundColor="#E8F8F7"
                         StrokeThickness="0"
                         StrokeShape="RoundRectangle 16"
                         WidthRequest="32"
                         HeightRequest="32"
                         VerticalOptions="End">
                        <Image Source="logo.png"
                            HorizontalOptions="Fill"
                            VerticalOptions="Fill"
                            Aspect="AspectFit"
                            Margin="4"/>
                    </Border>
                    <VerticalStackLayout Grid.Column="1" Spacing="3">
                        <Border BackgroundColor="White"
                             Stroke="#E0E0D8"
                             StrokeThickness="0.5"
                             StrokeShape="RoundRectangle 14,14,14,4"
                             Padding="12,9">
                            <Label Text="{Binding Text}"
                                FontSize="13"
                                LineHeight="1.5"
                                TextColor="#2C2C2A"/>
                        </Border>
                        <Label Text="{Binding Time}"
                            FontSize="10"
                            Margin="4,0,0,0"
                            TextColor="#B4B2A9"/>
                    </VerticalStackLayout>
                </Grid>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="UserMessageTemplate">
            <Grid Margin="48,4,0,4">
                <VerticalStackLayout Spacing="3" HorizontalOptions="End">
                    <Border BackgroundColor="#2EBBB0"
                         StrokeThickness="0"
                         StrokeShape="RoundRectangle 14,14,4,14"
                         Padding="12,9">
                        <Label Text="{Binding Text}"
                            FontSize="13"
                            LineHeight="1.5"
                            TextColor="White"/>
                    </Border>
                    <Label Text="{Binding Time}"
                        FontSize="10"
                        HorizontalOptions="End"
                        Margin="0,0,4,0"
                        TextColor="#B4B2A9"/>
                </VerticalStackLayout>
            </Grid>
        </DataTemplate>

    </ContentPage.Resources>

    <!-- 4 filas: header | mensajes | input | nav -->
    <Grid RowDefinitions="Auto,*,Auto,Auto">

        <!-- ── Header ── -->
        <Border Grid.Row="0"
             BackgroundColor="White"
             StrokeThickness="0.5"
             Stroke="#E0E0D8"
             Padding="12,50,12,12"
             StrokeShape="RoundRectangle 0">
            <Grid ColumnDefinitions="40,*,40" ColumnSpacing="8">

                <Border Grid.Column="0"
                     BackgroundColor="#E8F8F7"
                     StrokeThickness="0"
                     StrokeShape="RoundRectangle 12"
                     WidthRequest="38"
                     HeightRequest="38"
                     VerticalOptions="Center">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnVolverTapped"/>
                    </Border.GestureRecognizers>
                    <Label Text="←"
                        FontSize="18"
                        TextColor="#2EBBB0"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"/>
                </Border>

                <HorizontalStackLayout Grid.Column="1"
                                    HorizontalOptions="Center"
                                    Spacing="10"
                                    VerticalOptions="Center">
                    <Grid WidthRequest="36" HeightRequest="36">
                        <Border BackgroundColor="#E8F8F7"
                         StrokeThickness="0"
                         StrokeShape="RoundRectangle 18"
                         WidthRequest="36"
                         HeightRequest="36"
                         Padding="0">
                            <Image Source="logo.png"
                            HorizontalOptions="Fill"
                            VerticalOptions="Fill"
                            Aspect="AspectFit" 
                            Margin="4"/>
                        </Border>
                        <Border x:Name="StatusDot"
                             BackgroundColor="#1D9E75"
                             StrokeThickness="1.5"
                             Stroke="White"
                             StrokeShape="RoundRectangle 5"
                             WidthRequest="9"
                             HeightRequest="9"
                             HorizontalOptions="End"
                             VerticalOptions="End"/>
                    </Grid>
                    <VerticalStackLayout VerticalOptions="Center" Spacing="1">
                        <Label Text="SALOVET AI"
                            FontSize="14"
                            FontAttributes="Bold"
                            TextColor="#333"/>
                        <Label x:Name="StatusLabel"
                            Text="En línea"
                            FontSize="11"
                            TextColor="#1D9E75"/>
                    </VerticalStackLayout>
                </HorizontalStackLayout>

                <VerticalStackLayout Grid.Column="2"
                                  VerticalOptions="Center"
                                  HorizontalOptions="Center"
                                  Spacing="4">
                    <BoxView WidthRequest="4" HeightRequest="4" CornerRadius="2" Color="#D3D1C7"/>
                    <BoxView WidthRequest="4" HeightRequest="4" CornerRadius="2" Color="#D3D1C7"/>
                    <BoxView WidthRequest="4" HeightRequest="4" CornerRadius="2" Color="#D3D1C7"/>
                </VerticalStackLayout>

            </Grid>
        </Border>

        <!-- ── Lista de mensajes ── -->
        <CollectionView x:Name="MessagesCollection"
                     Grid.Row="1"
                     BackgroundColor="Transparent"
                     Margin="12,0"
                     ItemsUpdatingScrollMode="KeepLastItemInView">
            <CollectionView.Header>
                <Border BackgroundColor="White"
                     StrokeThickness="0.5"
                     Stroke="#E0E0D8"
                     StrokeShape="RoundRectangle 10"
                     Padding="10,4"
                     HorizontalOptions="Center"
                     Margin="0,12,0,8">
                    <Label Text="Hoy" FontSize="11" TextColor="#888780"/>
                </Border>
            </CollectionView.Header>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <ContentView x:Name="MessageView"/>
                </DataTemplate>
            </CollectionView.ItemTemplate>
            <CollectionView.Footer>
                <Grid x:Name="TypingIndicator"
                   IsVisible="False"
                   Margin="0,4,48,8">
                    <Grid ColumnDefinitions="32,*" ColumnSpacing="8">
                        <Border Grid.Column="0"
                             BackgroundColor="#E8F8F7"
                             StrokeThickness="0"
                             StrokeShape="RoundRectangle 16"
                             WidthRequest="32"
                             HeightRequest="32"
                             VerticalOptions="End">
                            <Image Source="logo.png"
                                HorizontalOptions="Fill"
                                VerticalOptions="Fill"
                                Aspect="AspectFit"
                                Margin="4"/>
                        </Border>
                        <Border Grid.Column="1"
                             BackgroundColor="White"
                             Stroke="#E0E0D8"
                             StrokeThickness="0.5"
                             StrokeShape="RoundRectangle 14,14,14,4"
                             Padding="14,10"
                             HorizontalOptions="Start">
                            <HorizontalStackLayout Spacing="5" VerticalOptions="Center">
                                <Ellipse x:Name="Dot1" Fill="#B4B2A9" WidthRequest="6" HeightRequest="6"/>
                                <Ellipse x:Name="Dot2" Fill="#B4B2A9" WidthRequest="6" HeightRequest="6"/>
                                <Ellipse x:Name="Dot3" Fill="#B4B2A9" WidthRequest="6" HeightRequest="6"/>
                            </HorizontalStackLayout>
                        </Border>
                    </Grid>
                </Grid>
            </CollectionView.Footer>
        </CollectionView>

        <!-- ── Barra de input ── -->
        <Border Grid.Row="2"
             BackgroundColor="White"
             StrokeThickness="0.5"
             Stroke="#E0E0D8"
             StrokeShape="RoundRectangle 0"
             Padding="12,10">
            <VerticalStackLayout Spacing="8">

                <!-- Chips de respuesta rápida -->
                <ScrollView Orientation="Horizontal"
                         HorizontalScrollBarVisibility="Never">
                    <HorizontalStackLayout Spacing="6">
                        <Border BackgroundColor="#E8F8F7"
                             Stroke="#2EBBB0"
                             StrokeThickness="0.5"
                             StrokeShape="RoundRectangle 12"
                             Padding="10,5">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnQuickReply1"/>
                            </Border.GestureRecognizers>
                            <Label Text="¿Qué vacunas necesita?" FontSize="11" TextColor="#2EBBB0"/>
                        </Border>
                        <Border BackgroundColor="#E8F8F7"
                             Stroke="#2EBBB0"
                             StrokeThickness="0.5"
                             StrokeShape="RoundRectangle 12"
                             Padding="10,5">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnQuickReply2"/>
                            </Border.GestureRecognizers>
                            <Label Text="¿Cuánto ejercicio?" FontSize="11" TextColor="#2EBBB0"/>
                        </Border>
                        <Border BackgroundColor="#E8F8F7"
                             Stroke="#2EBBB0"
                             StrokeThickness="0.5"
                             StrokeShape="RoundRectangle 12"
                             Padding="10,5">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnQuickReply3"/>
                            </Border.GestureRecognizers>
                            <Label Text="Consejos de higiene" FontSize="11" TextColor="#2EBBB0"/>
                        </Border>
                    </HorizontalStackLayout>
                </ScrollView>

                <!-- Campo de texto + botón enviar -->
                <Grid ColumnDefinitions="*,44" ColumnSpacing="8">
                    <Border Grid.Column="0"
                         BackgroundColor="#F5F5F0"
                         Stroke="#E0E0D8"
                         StrokeThickness="0.5"
                         StrokeShape="RoundRectangle 20"
                         Padding="12,0">
                        <Editor x:Name="MessageInput"
                             Placeholder="Escribe un mensaje..."
                             PlaceholderColor="#B4B2A9"
                             FontSize="14"
                             TextColor="#2C2C2A"
                             BackgroundColor="Transparent"
                             AutoSize="TextChanges"
                             MinimumHeightRequest="44"
                             MaximumHeightRequest="100"/>
                    </Border>
                    <Border Grid.Column="1"
                         BackgroundColor="#2EBBB0"
                         StrokeThickness="0"
                         StrokeShape="RoundRectangle 22"
                         WidthRequest="44"
                         HeightRequest="44"
                         VerticalOptions="End">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnSendTapped"/>
                        </Border.GestureRecognizers>
                        <Label Text="➤"
                            FontSize="16"
                            TextColor="White"
                            HorizontalOptions="Center"
                            VerticalOptions="Center"
                            Margin="2,0,0,0"/>
                    </Border>
                </Grid>

            </VerticalStackLayout>
        </Border>

        <!-- ── Barra de navegación inferior ── -->
        <Border Grid.Row="3"
             BackgroundColor="White"
             StrokeThickness="0.5"
             Stroke="#E0E0D8"
             Padding="10,10,10,30">
            <Grid ColumnDefinitions="*,*,*,*">

                <!-- IA -->
                <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="4">
                    <Border BackgroundColor="#2EBBB0"
                         StrokeThickness="0"
                         StrokeShape="RoundRectangle 12"
                         WidthRequest="44"
                         HeightRequest="44"
                         HorizontalOptions="Center">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnChatTapped"/>
                        </Border.GestureRecognizers>
                        <Label Text="🐾" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                </VerticalStackLayout>

                <!-- Inicio -->
                <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="4">
                    <Border BackgroundColor="#F5F5F0"
                         StrokeThickness="0"
                         StrokeShape="RoundRectangle 16"
                         WidthRequest="52"
                         HeightRequest="52"
                         HorizontalOptions="Center">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnInicioTapped"/>
                        </Border.GestureRecognizers>
                        <Label Text="🏠" FontSize="24" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                </VerticalStackLayout>

                <!-- Citas -->
                <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="4">
                    <Border BackgroundColor="#F5F5F0"
                         StrokeThickness="0"
                         StrokeShape="RoundRectangle 12"
                         WidthRequest="44"
                         HeightRequest="44"
                         HorizontalOptions="Center">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnNavCitasTapped"/>
                        </Border.GestureRecognizers>
                        <Label Text="📅" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                </VerticalStackLayout>

                <!-- Perfil -->
                <VerticalStackLayout Grid.Column="3" HorizontalOptions="Center" Spacing="4">
                    <Border BackgroundColor="#F5F5F0"
                         StrokeThickness="0"
                         StrokeShape="RoundRectangle 12"
                         WidthRequest="44"
                         HeightRequest="44"
                         HorizontalOptions="Center">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnNavPerfilTapped"/>
                        </Border.GestureRecognizers>
                        <Label Text="👤" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                </VerticalStackLayout>

            </Grid>
        </Border>

    </Grid>
</ContentPage>