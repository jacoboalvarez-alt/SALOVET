<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MECAGOENELTFG.Views2.ClienteEditarPerfilPage"
             Shell.NavBarIsVisible="False"
             BackgroundImageSource="fondo.png"
             Title="Editar Perfil">

    <Grid RowDefinitions="Auto,*">
        <!-- Header Adaptable -->
        <Border Grid.Row="0" StrokeThickness="0" Padding="20,40,20,15">
            <Grid ColumnDefinitions="*,Auto" VerticalOptions="End">
                <VerticalStackLayout Grid.Column="0" Spacing="2">
                    <Label Text="Configuración" FontSize="12" TextColor="#C8F0EE" />
                    <Label Text="Editar Perfil" FontSize="20" FontAttributes="Bold" TextColor="White" />
                </VerticalStackLayout>

                <Button Grid.Column="1" 
                        Text="GUARDAR" 
                        Command="{Binding GuardarCommand}"
                        BackgroundColor="White" 
                        TextColor="#2EBBB0" 
                        FontAttributes="Bold" 
                        FontSize="12"
                        HeightRequest="36"
                        Padding="15,0"
                        CornerRadius="18"/>
            </Grid>
        </Border>
        <!-- Contenedor Principal con Scroll para el Teclado -->
        <ScrollView Grid.Row="1" VerticalScrollBarVisibility="Never">
            <Border BackgroundColor="#F5F5F0" 
                    StrokeShape="RoundRectangle 24,24,0,0" 
                    Padding="16,25,16,30"
                    VerticalOptions="FillAndExpand">

                <VerticalStackLayout Spacing="18">

                    <!-- SECCIÓN: DATOS PERSONALES -->
                    <Label Text="DATOS PERSONALES" FontAttributes="Bold" FontSize="12" TextColor="#888780" Margin="5,0"/>

                        <Border BackgroundColor="White" StrokeShape="RoundRectangle 12" Padding="15,5" StrokeThickness="0">
                            <VerticalStackLayout Spacing="10">
                                <!-- Campo Nombre -->
                                <VerticalStackLayout Spacing="2">
                                    <Label Text="Nombre" FontSize="18" TextColor="#2EBBB0" FontAttributes="Bold"/>
                                <Entry Text="{Binding Nombre}" 
                                       Placeholder="Escribe tu nombre"
                                       FontSize="15"
                                       TextColor="#2C2C2A" />
                            </VerticalStackLayout>

                                <BoxView HeightRequest="1" Color="#F0F0F0"/>

                                    <!-- Campo Apellidos -->
                                    <VerticalStackLayout Spacing="2">
                                        <Label Text="Apellidos" FontSize="18" TextColor="#2EBBB0" FontAttributes="Bold"/>
                                            <Entry Text="{Binding Apellidos}" 
                                       Placeholder="Escribe tus apellidos"
                                       FontSize="15"
                                       TextColor="#2C2C2A"/>
                                    </VerticalStackLayout>
                            </VerticalStackLayout>
                        </Border>

                        <!-- SECCIÓN: CONTACTO -->
                    <Label Text="CONTACTO" FontAttributes="Bold" FontSize="12" TextColor="#888780" Margin="5,10,0,0" />

                    <Border BackgroundColor="White" StrokeShape="RoundRectangle 12" Padding="15,5" StrokeThickness="0">
                                <VerticalStackLayout Spacing="10">
                                    <!-- Email -->
                                    <VerticalStackLayout Spacing="2">
                                <Label Text="Correo electrónico" FontSize="18" TextColor="#2EBBB0" FontAttributes="Bold" />
                                <Entry Text="{Binding Email}" 
                                       Keyboard="Email"
                                       FontSize="15"
                                       TextColor="#2C2C2A" />
                            </VerticalStackLayout>

                            <BoxView HeightRequest="1" Color="#F0F0F0" />

                            <!-- Teléfono -->
                                        <VerticalStackLayout Spacing="2">
                                <Label Text="Teléfono" FontSize="18" TextColor="#2EBBB0" FontAttributes="Bold" />
                                <Entry Text="{Binding Telefono}" 
                                       Keyboard="Telephone"
                                       FontSize="15"
                                       TextColor="#2C2C2A" />
                            </VerticalStackLayout>
                                </VerticalStackLayout>
                            </Border>

                            <!-- SECCIÓN: SOLO LECTURA -->
                            <Border BackgroundColor="#E9E9E4" StrokeShape="RoundRectangle 12" Padding="15,12" StrokeThickness="0" Opacity="0.8">
                                <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Edad (no modificable)" VerticalOptions="Center" FontSize="18" TextColor="#666" />
                            <Label Grid.Column="1" Text="{Binding Edad, StringFormat='{0} años'}" FontAttributes="Bold" VerticalOptions="Center" TextColor="#2C2C2A" />
                        </Grid>
                            </Border>

                            <!-- Botón Cancelar discreto -->
                    <Button Text="Cancelar cambios" 
                            Command="{Binding CancelarCommand}"
                            BackgroundColor="Transparent"
                            TextColor="#888780"
                            FontSize="13"
                            Margin="0,10"/>
                </VerticalStackLayout>
            </Border>
        </ScrollView>
    </Grid>

</ContentPage>