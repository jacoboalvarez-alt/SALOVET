<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MECAGOENELTFG.Views.ClientDashBoard"
             xmlns:vm="clr-namespace:MECAGOENELTFG.ViewModels"
             Title="ClientDashBoard"
             BackgroundImageSource="fondo.png"
             Shell.NavBarIsVisible="False">
    <Shell.TitleView>
        <Label Text="" IsVisible="False"/>
    </Shell.TitleView>

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- ── Header ── -->
        <Border Grid.Row="0"
            StrokeThickness="0"
            Padding="20,50,20,16">
            <Grid ColumnDefinitions="*,Auto">
                <VerticalStackLayout Grid.Column="0" Spacing="2">
                    <Label Text="¡Bienvenido!"
                       FontSize="13"
                       TextColor="#C8F0EE"/>
                    <Label x:Name="NombreClienteLabel"
                       Text="Cliente"
                       FontSize="22"
                       FontAttributes="Bold"
                       TextColor="White"/>
                </VerticalStackLayout>
                <Button Grid.Column="1"
                    Text="SALIR"
                    BackgroundColor="White"
                    TextColor="#2EBBB0"
                    FontAttributes="Bold"
                    FontSize="13"
                    CornerRadius="20"
                    HeightRequest="38"
                    WidthRequest="80"
                    Clicked="OnSalirClicked"/>
            </Grid>
        </Border>

        <!-- ── Contenido principal ── -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="0">

                <!-- Fondo blanco redondeado que cubre el contenido -->
                <Border BackgroundColor="#F5F5F0"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 24,24,0,0"
                    Padding="16,20,16,30">
                    <VerticalStackLayout Spacing="20">

                        <!-- ── SECCIÓN NOTICIAS ── -->
                        <VerticalStackLayout Spacing="10">
                            <Label Text="NOTICIAS"
                               FontAttributes="Bold"
                               FontSize="13"
                               TextColor="#888780"
                               Margin="4,0"/>

                            <!-- Carrusel -->
                            <Border BackgroundColor="White"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 16"
                                HeightRequest="200">
                                <Grid>
                                    <CarouselView x:Name="NoticiasCarousel"
                                              Loop="True"
                                              IndicatorView="NoticiasIndicator"
                                              IsScrollAnimated="True"
                                              HeightRequest="200">
                                        <CarouselView.ItemTemplate>
                                            <DataTemplate>
                                                <Grid>
                                                    <Image Source="{Binding Imagen}"
                                                       Aspect="AspectFill"/>
                                                    <!-- Gradiente inferior sobre la imagen -->
                                                    <Border StrokeThickness="0"
                                                        StrokeShape="RoundRectangle 16"
                                                        BackgroundColor="Transparent">
                                                        <Grid VerticalOptions="End"
                                                          Padding="14,10">
                                                            <Border BackgroundColor="#80000000"
                                                                StrokeThickness="0"
                                                                StrokeShape="RoundRectangle 8"
                                                                Padding="10,6">
                                                                <Label Text="{Binding Titulo}"
                                                                   TextColor="White"
                                                                   FontAttributes="Bold"
                                                                   FontSize="14"/>
                                                            </Border>
                                                        </Grid>
                                                    </Border>
                                                </Grid>
                                            </DataTemplate>
                                        </CarouselView.ItemTemplate>
                                    </CarouselView>

                                    <!-- Indicadores de posición -->
                                    <IndicatorView x:Name="NoticiasIndicator"
                                               IndicatorColor="#C8F0EE"
                                               SelectedIndicatorColor="#2EBBB0"
                                               VerticalOptions="End"
                                               HorizontalOptions="Center"
                                               Margin="0,0,0,8"/>
                                </Grid>
                            </Border>
                        </VerticalStackLayout>

                        <!-- ── SECCIÓN CITAS ── -->
                        <VerticalStackLayout Spacing="10">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0"
                                   Text="TUS CITAS"
                                   FontAttributes="Bold"
                                   FontSize="13"
                                   TextColor="#888780"
                                   Margin="4,0"/>
                                <Label Grid.Column="1"
                                   Text="Ver todas →"
                                   FontSize="12"
                                   TextColor="#2EBBB0" 
                                   VerticalOptions="Center">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnNavCitasTapped" />
                                    </Label.GestureRecognizers>
                                </Label>
                            </Grid>

                            <!-- Lista de citas -->
                            <VerticalStackLayout x:Name="CitasContainer" Spacing="10">
                                <!-- Placeholder si no hay citas -->
                                <Border x:Name="SinCitasPlaceholder"
                                    BackgroundColor="White"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 14"
                                    Padding="20"
                                    IsVisible="False">
                                    <VerticalStackLayout HorizontalOptions="Center" Spacing="8">
                                        <Label Text="📅" FontSize="32" HorizontalOptions="Center"/>
                                        <Label Text="No tienes citas programadas"
                                       FontSize="13" TextColor="#888780"
                                       HorizontalOptions="Center"/>
                                    </VerticalStackLayout>
                                </Border>
                            </VerticalStackLayout>
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>

        <!-- ── Barra de navegación inferior ── -->
        <Border Grid.Row="2"
            BackgroundColor="White"
            StrokeThickness="0.5"
            Stroke="#E0E0D8"
            StrokeShape="RoundRectangle 0"
            Padding="10,10,10,30">
            <Grid ColumnDefinitions="*,*,*,*">

                <!-- Botón 1 (placeholder) -->
                <VerticalStackLayout Grid.Column="0"
                                 HorizontalOptions="Center"
                                 Spacing="4">
                    <Border Grid.Column="0"
                    BackgroundColor="#F5F5F0"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 12"
                    WidthRequest="44"
                    HeightRequest="44"
                    HorizontalOptions="Center">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnChatTapped"/>
                        </Border.GestureRecognizers>
                        <Label Text="🐾"
                   FontSize="20"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"/>
                    </Border>
                </VerticalStackLayout>

                <!-- Botón INICIO (funcional) -->
                <VerticalStackLayout Grid.Column="1"
                                 HorizontalOptions="Center"
                                 Spacing="4">
                    <Border BackgroundColor="#2EBBB0"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 16"
                        WidthRequest="52"
                        HeightRequest="52"
                        HorizontalOptions="Center">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnInicioTapped"/>
                        </Border.GestureRecognizers>
                        <Label Text="🏠"
                           FontSize="24"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                    </Border>
                </VerticalStackLayout>

                <!-- Botón 4 (placeholder) -->
                <VerticalStackLayout Grid.Column="2"
                                 HorizontalOptions="Center"
                                 Spacing="4">
                    <Border BackgroundColor="#F5F5F0"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 12"
                        WidthRequest="44"
                        HeightRequest="44"
                        HorizontalOptions="Center">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnNavCitasTapped"/>
                        </Border.GestureRecognizers>
                        <Label Text="📅"
                           FontSize="20"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                    </Border>
                </VerticalStackLayout>

                <!-- Botón 5 (placeholder) -->
                <VerticalStackLayout Grid.Column="4"
                                 HorizontalOptions="Center"
                                 Spacing="4">
                    <Border BackgroundColor="#F5F5F0"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 12"
                        WidthRequest="44"
                        HeightRequest="44"
                        HorizontalOptions="Center">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnNavPerfilTapped"/>
                        </Border.GestureRecognizers>
                        <Label Text="👤"
                           FontSize="20"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                    </Border>
                </VerticalStackLayout>

            </Grid>
        </Border>

    </Grid>
</ContentPage>