<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MECAGOENELTFG.Views2.CitasPageClient"
             x:Name="CitasPage"
             Shell.NavBarIsVisible="False"
             BackgroundImageSource="fondo.png"
             Title="Citas">

    <Shell.TitleView>
        <Label Text="" IsVisible="False"/>
    </Shell.TitleView>

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- HEADER -->
        <Border Grid.Row="0"
                StrokeThickness="0"
                Padding="20,50,20,16">
            <VerticalStackLayout Spacing="2">
                <Label Text="Gestión"
                       FontSize="13"
                       TextColor="#C8F0EE"/>
                <Label Text="Mis citas"
                       FontSize="22"
                       FontAttributes="Bold"
                       TextColor="White"/>
            </VerticalStackLayout>
        </Border>

        <!-- CONTENIDO -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="0">

                <Border BackgroundColor="#F5F5F0"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 24,24,0,0"
                        Padding="16,20,16,30">

                    <VerticalStackLayout Spacing="20">

                        <!-- FILTROS -->
                        <HorizontalStackLayout Spacing="8">

                            <!-- FILTRO: TODAS -->
                            <Border StrokeThickness="0"
                                    StrokeShape="RoundRectangle 20"
                                    Padding="14,6">

                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="BackgroundColor"
                                                Value="{Binding Source={x:Reference CitasPage},
                                                                Path=BindingContext.FiltroActivo,
                                                                Converter={StaticResource FiltroColorConverter},
                                                                ConverterParameter=Todas}"/>
                                    </Style>
                                </Border.Style>

                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding CambiarFiltroCommand}"
                                                          CommandParameter="Todas"/>
                                </Border.GestureRecognizers>

                                <Label Text="Todas"
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       TextColor="{Binding Source={x:Reference CitasPage},
                                                           Path=BindingContext.FiltroActivo,
                                                           Converter={StaticResource FiltroTextoConverter},
                                                           ConverterParameter=Todas}"/>
                            </Border>

                            <!-- FILTRO: PRÓXIMAS -->
                            <Border StrokeThickness="0"
                                    StrokeShape="RoundRectangle 20"
                                    Padding="14,6">

                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="BackgroundColor"
                                                Value="{Binding Source={x:Reference CitasPage},
                                                                Path=BindingContext.FiltroActivo,
                                                                Converter={StaticResource FiltroColorConverter},
                                                                ConverterParameter=Próximas}"/>
                                    </Style>
                                </Border.Style>

                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding CambiarFiltroCommand}"
                                                          CommandParameter="Próximas"/>
                                </Border.GestureRecognizers>

                                <Label Text="Próximas"
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       TextColor="{Binding Source={x:Reference CitasPage},
                                                           Path=BindingContext.FiltroActivo,
                                                           Converter={StaticResource FiltroTextoConverter},
                                                           ConverterParameter=Próximas}"/>
                            </Border>

                            <!-- FILTRO: PASADAS -->
                            <Border StrokeThickness="0"
                                    StrokeShape="RoundRectangle 20"
                                    Padding="14,6">

                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="BackgroundColor"
                                                Value="{Binding Source={x:Reference CitasPage},
                                                                Path=BindingContext.FiltroActivo,
                                                                Converter={StaticResource FiltroColorConverter},
                                                                ConverterParameter=Pasadas}"/>
                                    </Style>
                                </Border.Style>

                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding CambiarFiltroCommand}"
                                                          CommandParameter="Pasadas"/>
                                </Border.GestureRecognizers>

                                <Label Text="Pasadas"
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       TextColor="{Binding Source={x:Reference CitasPage},
                                                           Path=BindingContext.FiltroActivo,
                                                           Converter={StaticResource FiltroTextoConverter},
                                                           ConverterParameter=Pasadas}"/>
                            </Border>

                        </HorizontalStackLayout>

                        <!-- PRÓXIMAS -->
                        <VerticalStackLayout Spacing="10"
                                             IsVisible="{Binding MostrarProximas}">

                            <Label Text="PRÓXIMAS"
                                   FontAttributes="Bold"
                                   FontSize="13"
                                   TextColor="#888780"
                                   Margin="4,0"/>

                            <CollectionView ItemsSource="{Binding CitasProximas}"
                                            SelectionMode="None">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Border BackgroundColor="White"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 14"
                                                Padding="14"
                                                Margin="0,0,0,8">

                                            <VerticalStackLayout Spacing="0">

                                                <Grid ColumnDefinitions="Auto,*,Auto"
                                                      ColumnSpacing="12">

                                                    <!-- Fecha -->
                                                    <Border Grid.Column="0"
                                                            BackgroundColor="#E8F8F7"
                                                            StrokeThickness="0"
                                                            StrokeShape="RoundRectangle 10"
                                                            WidthRequest="48"
                                                            HeightRequest="48">
                                                        <VerticalStackLayout HorizontalOptions="Center"
                                                                             VerticalOptions="Center"
                                                                             Spacing="0">
                                                            <Label Text="{Binding MesCorto}"
                                                                   FontSize="9"
                                                                   FontAttributes="Bold"
                                                                   TextColor="#2EBBB0"/>
                                                            <Label Text="{Binding Dia}"
                                                                   FontSize="20"
                                                                   FontAttributes="Bold"
                                                                   TextColor="#2EBBB0"/>
                                                        </VerticalStackLayout>
                                                    </Border>

                                                    <!-- Info -->
                                                    <VerticalStackLayout Grid.Column="1"
                                                                         VerticalOptions="Center"
                                                                         Spacing="2">
                                                        <Label Text="{Binding Titulo}"
                                                               FontAttributes="Bold"
                                                               FontSize="14"
                                                               TextColor="#2C2C2A"/>
                                                        <Label Text="{Binding HoraYVeterinario}"
                                                               FontSize="12"
                                                               TextColor="#888780"/>
                                                        <Label Text="{Binding NombreMascota}"
                                                               FontSize="12"
                                                               TextColor="#888780"/>
                                                    </VerticalStackLayout>

                                                    <!-- Badge -->
                                                    <Border Grid.Column="2"
                                                            BackgroundColor="#E8F8F7"
                                                            StrokeThickness="0"
                                                            StrokeShape="RoundRectangle 8"
                                                            Padding="8,4"
                                                            VerticalOptions="Center">
                                                        <Label Text="Próxima"
                                                               FontSize="11"
                                                               FontAttributes="Bold"
                                                               TextColor="#2EBBB0"/>
                                                    </Border>

                                                </Grid>

                                                <!-- Acciones -->
                                                <Grid ColumnDefinitions="*,*"
                                                      ColumnSpacing="8"
                                                      Margin="0,10,0,0">

                                                    <Border Grid.Column="0"
                                                            BackgroundColor="#E8F8F7"
                                                            StrokeThickness="0"
                                                            StrokeShape="RoundRectangle 8"
                                                            Padding="0,8">
                                                        <Border.GestureRecognizers>
                                                            <TapGestureRecognizer
                                                                Command="{Binding Source={x:Reference CitasPage}, Path=BindingContext.ModificarCitaCommand}"
                                                                CommandParameter="{Binding .}"/>
                                                        </Border.GestureRecognizers>
                                                        <Label Text="Modificar"
                                                               FontSize="12"
                                                               FontAttributes="Bold"
                                                               TextColor="#2EBBB0"
                                                               HorizontalOptions="Center"/>
                                                    </Border>

                                                    <Border Grid.Column="1"
                                                            BackgroundColor="#FEF0EE"
                                                            StrokeThickness="0"
                                                            StrokeShape="RoundRectangle 8"
                                                            Padding="0,8">
                                                        <Border.GestureRecognizers>
                                                            <TapGestureRecognizer
                                                                Command="{Binding Source={x:Reference CitasPage}, Path=BindingContext.CancelarCitaCommand}"
                                                                CommandParameter="{Binding .}"/>
                                                        </Border.GestureRecognizers>
                                                        <Label Text="Cancelar"
                                                               FontSize="12"
                                                               FontAttributes="Bold"
                                                               TextColor="#D85A30"
                                                               HorizontalOptions="Center"/>
                                                    </Border>

                                                </Grid>

                                            </VerticalStackLayout>

                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>

                            <!-- Sin próximas -->
                            <Border BackgroundColor="White"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 14"
                                    Padding="20"
                                    IsVisible="{Binding SinCitasProximas}">
                                <VerticalStackLayout HorizontalOptions="Center"
                                                     Spacing="8">
                                    <Label Text="📅"
                                           FontSize="32"/>
                                    <Label Text="No tienes citas próximas"
                                           FontSize="13"
                                           TextColor="#888780"/>
                                </VerticalStackLayout>
                            </Border>

                        </VerticalStackLayout>

                        <!-- HISTORIAL -->
                        <VerticalStackLayout Spacing="10"
                                             IsVisible="{Binding MostrarPasadas}">

                            <Label Text="HISTORIAL"
                                   FontAttributes="Bold"
                                   FontSize="13"
                                   TextColor="#888780"
                                   Margin="4,0"/>

                            <CollectionView ItemsSource="{Binding CitasPasadas}"
                                            SelectionMode="None">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Border BackgroundColor="White"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 14"
                                                Padding="14"
                                                Margin="0,0,0,8"
                                                Opacity="0.75">

                                            <Grid ColumnDefinitions="Auto,*,Auto"
                                                  ColumnSpacing="12">

                                                <Border Grid.Column="0"
                                                        BackgroundColor="#F5F5F0"
                                                        StrokeThickness="0"
                                                        StrokeShape="RoundRectangle 10"
                                                        WidthRequest="48"
                                                        HeightRequest="48">
                                                    <VerticalStackLayout HorizontalOptions="Center"
                                                                         VerticalOptions="Center"
                                                                         Spacing="0">
                                                        <Label Text="{Binding MesCorto}"
                                                               FontSize="9"
                                                               FontAttributes="Bold"
                                                               TextColor="#888780"/>
                                                        <Label Text="{Binding Dia}"
                                                               FontSize="20"
                                                               FontAttributes="Bold"
                                                               TextColor="#888780"/>
                                                    </VerticalStackLayout>
                                                </Border>

                                                <VerticalStackLayout Grid.Column="1"
                                                                     VerticalOptions="Center"
                                                                     Spacing="2">
                                                    <Label Text="{Binding Titulo}"
                                                           FontAttributes="Bold"
                                                           FontSize="14"
                                                           TextColor="#2C2C2A"/>
                                                    <Label Text="{Binding HoraYVeterinario}"
                                                           FontSize="12"
                                                           TextColor="#888780"/>
                                                    <Label Text="{Binding NombreMascota}"
                                                           FontSize="12"
                                                           TextColor="#888780"/>
                                                </VerticalStackLayout>

                                                <Border Grid.Column="2"
                                                        BackgroundColor="#F5F5F0"
                                                        StrokeThickness="0"
                                                        StrokeShape="RoundRectangle 8"
                                                        Padding="8,4"
                                                        VerticalOptions="Center">
                                                    <Label Text="Pasada"
                                                           FontSize="11"
                                                           FontAttributes="Bold"
                                                           TextColor="#888780"/>
                                                </Border>

                                            </Grid>

                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>

                        </VerticalStackLayout>

                        <!-- BOTÓN NUEVA CITA -->
                        <Border BackgroundColor="#2EBBB0"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 14"
                                Padding="16,16">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SolicitarCitaCommand}"/>
                            </Border.GestureRecognizers>
                            <Label Text="+ Solicitar nueva cita"
                                   FontAttributes="Bold"
                                   FontSize="15"
                                   TextColor="White"
                                   HorizontalOptions="Center"/>
                        </Border>

                    </VerticalStackLayout>

                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- NAVBAR -->
        <Border Grid.Row="2"
                BackgroundColor="White"
                StrokeThickness="0.5"
                Stroke="#E0E0D8"
                Padding="10,10,10,30">

            <Grid ColumnDefinitions="*,*,*,*">

                <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="4">
                    <Border BackgroundColor="#F5F5F0"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 12"
                            WidthRequest="44"
                            HeightRequest="44">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnChatTapped"/>
                        </Border.GestureRecognizers>
                        <Label Text="🐾"
                               FontSize="20"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="4">
                    <Border BackgroundColor="#F5F5F0"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 16"
                            WidthRequest="52"
                            HeightRequest="52">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnInicioTapped"/>
                        </Border.GestureRecognizers>
                        <Label Text="🏠"
                               FontSize="24"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="4">
                    <Border BackgroundColor="#2EBBB0"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 12"
                            WidthRequest="44"
                            HeightRequest="44">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnNavCitasTapped"/>
                        </Border.GestureRecognizers>
                        <Label Text="📅"
                               FontSize="20"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="3" HorizontalOptions="Center" Spacing="4">
                    <Border BackgroundColor="#F5F5F0"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 12"
                            WidthRequest="44"
                            HeightRequest="44">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnNavPerfilTapped"/>
                        </Border.GestureRecognizers>
                        <Label Text="👤"
                               FontSize="20"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>
                </VerticalStackLayout>

            </Grid>

        </Border>

    </Grid>

</ContentPage>
