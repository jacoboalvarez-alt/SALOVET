<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MECAGOENELTFG.Views.ClienteFormPage"
             xmlns:vm="clr-namespace:MECAGOENELTFG.ViewModels"
             Title="ClienteFormPage"
             BackgroundImageSource="fondo2.png"
             Shell.NavBarIsVisible="False">
    <ContentPage.BindingContext>
        <vm:ClienteFormViewModel />
    </ContentPage.BindingContext>


    <ScrollView Padding="20">
        <VerticalStackLayout Spacing="15">
            <Button WidthRequest="200" HorizontalOptions="End" BackgroundColor="#2EBBB0"
                    Text="← Volver" Command="{Binding IrADashboardCommand}" />
            <Label Text="AGREGAR NUEVO CLIENTE"
                   HorizontalOptions="Center" 
                   VerticalOptions="Center" TextColor="White" FontAttributes="Bold"
                   FontSize="40" FontFamily="Milano"
                   Margin="0,30,0,0"/>

            <!-- Formulario dentro de un Border blanco -->
            <Border BackgroundColor="White"
                    StrokeShape="RoundRectangle 16"
                    Stroke="Transparent"
                    Padding="25" WidthRequest="600"
                    Margin="0,10,0,20">
                <VerticalStackLayout Spacing="15">

                    <!-- Nombre -->
                    <VerticalStackLayout Spacing="5">
                        <Label Text="Nombre *" 
                               FontAttributes="Bold" 
                               TextColor="#333" />
                        <Entry Text="{Binding NombreCli}"
                               Placeholder="Ingrese el nombre"
                               MaxLength="200" HeightRequest="30" />
                    </VerticalStackLayout>

                    <!-- Apellido -->
                    <VerticalStackLayout Spacing="5">
                        <Label Text="Apellido *" 
                               FontAttributes="Bold"
                               TextColor="#333" />
                        <Entry Text="{Binding ApeCli}"
                               Placeholder="Ingrese el apellido"
                               MaxLength="100" HeightRequest="30" />
                    </VerticalStackLayout>

                    <!-- Edad -->
                    <VerticalStackLayout Spacing="5">
                        <Label Text="Edad *" 
                               FontAttributes="Bold"
                               TextColor="#333" />
                        <Entry Text="{Binding Edad}"
                               Placeholder="Ingrese la edad"
                               Keyboard="Numeric"
                               MaxLength="3" HeightRequest="30" />
                    </VerticalStackLayout>

                    <!-- Correo -->
                    <VerticalStackLayout Spacing="5">
                        <Label Text="Correo electrónico *" 
                               FontAttributes="Bold"
                               TextColor="#333" />
                        <Entry Text="{Binding Correo}"
                               Placeholder="ejemplo@email.com"
                               Keyboard="Email"
                               MaxLength="100" HeightRequest="30" />
                    </VerticalStackLayout>

                    <!-- Teléfono -->
                    <VerticalStackLayout Spacing="5">
                        <Label Text="Teléfono (opcional)" 
                               FontAttributes="Bold"
                               TextColor="#333" />
                        <Entry Text="{Binding Tel}"
                               Placeholder="Ingrese el teléfono"
                               Keyboard="Telephone"
                               MaxLength="100" HeightRequest="30" />
                    </VerticalStackLayout>

                    <!-- Nota -->
                    <Label Text="* Campos obligatorios"
                           FontSize="12"
                           TextColor="Gray" />

                    <!-- Botones pegados -->
                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="0"
                          Margin="0,10,0,0">

                        <Button Grid.Column="0"
                                Text="💾 Guardar"
                                Command="{Binding GuardarCommand}"
                                BackgroundColor="#4CAF50"
                                TextColor="White"
                                HeightRequest="50" Margin="10,0,0,0"
                                CornerRadius="30" />

                        <Button Grid.Column="1"
                                Text="❌ Cancelar"
                                Command="{Binding CancelarCommand}"
                                BackgroundColor="#F44336"
                                TextColor="White"
                                HeightRequest="50" Margin="10,0,0,0"
                                CornerRadius="30" />
                    </Grid>

                    <!-- Indicador de carga -->
                    <ActivityIndicator IsRunning="{Binding IsLoading}"
                                      IsVisible="{Binding IsLoading}"
                                      Color="#2196F3"
                                      WidthRequest="50"
                                      HeightRequest="50"
                                      Margin="0,10,0,0"
                                      HorizontalOptions="Center" />

                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>