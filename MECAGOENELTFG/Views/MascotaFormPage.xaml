<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MECAGOENELTFG.ViewModels"
             x:Class="MECAGOENELTFG.Views.MascotaFormPage"
             x:DataType="vm:MascotaFormViewModel"
             Shell.NavBarIsVisible="False"
             Title="{Binding TituloFormulario}"
             BackgroundImageSource="fondo2.png">

    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="16,16,16,32">
            <Button
               HorizontalOptions="End"
               WidthRequest="100"
                BackgroundColor="#FF6F61"
                Text="← Volver"
                Command="{Binding VolverCommand}"
                TextColor="White"
                />
            <!-- ── Cabecera cliente (solo lectura, viene de query param) ── -->
            <Border BackgroundColor="#E8F5F4"
                    StrokeThickness="0"
                    WidthRequest="900"
                    StrokeShape="RoundRectangle 14"
                    Padding="16,12"
                    IsVisible="{Binding MostrarSelectorCliente, Converter={StaticResource InverseBoolConverter}}">
                <HorizontalStackLayout Spacing="8" HorizontalOptions="Center">
                    <Label Text="👤" FontSize="16" VerticalOptions="Center"/>
                    <Label Text="{Binding NombreCliente}"
                           FontAttributes="Bold" FontSize="15"
                           TextColor="#1A7A72" VerticalOptions="Center"/>
                </HorizontalStackLayout>
            </Border>

            <!-- ════════════════════════════════════════════════════════
                 SECCIÓN 0 — CLIENTE (solo visible si no viene por query)
            ═══════════════════════════════════════════════════════════ -->
            <Label Text="CLIENTE" HorizontalOptions="Center" 
                   FontAttributes="Bold" FontSize="13"
                   TextColor="White" Margin="4,0,750,0"
                   IsVisible="{Binding MostrarSelectorCliente}"/>

            <Border BackgroundColor="White"
                    StrokeThickness="0"
                    WidthRequest="800"
                    StrokeShape="RoundRectangle 14"
                    Padding="16"
                    IsVisible="{Binding MostrarSelectorCliente}">
                <VerticalStackLayout Spacing="4">
                    <Label Text="Cliente *"
                           FontAttributes="Bold" FontSize="13" TextColor="#2C2C2A"/>
                    <Border BackgroundColor="#F5F5F0" StrokeThickness="0"
                            StrokeShape="RoundRectangle 10" Padding="12,0">
                        <!-- ItemDisplayBinding muestra NombreCli en el picker -->
                        <Picker ItemsSource="{Binding ClientesDisponibles}"
                                SelectedItem="{Binding ClienteSeleccionado, Mode=TwoWay}"
                                TextColor="#2C2C2A"
                                HeightRequest="44"
                                BackgroundColor="Transparent"/>
                    </Border>
                </VerticalStackLayout>
            </Border>

            <!-- ════════════════════════════════════════════════════════
                 SECCIÓN 1 — IDENTIFICACIÓN
            ═══════════════════════════════════════════════════════════ -->
            <Label Text="IDENTIFICACIÓN"
                   FontAttributes="Bold" FontSize="13" HorizontalOptions="Center"
                   TextColor="White" Margin="4,0,700,0"/>

            <Border BackgroundColor="White"
                    StrokeThickness="0" WidthRequest="800"
                    StrokeShape="RoundRectangle 14"
                    Padding="16">
                <VerticalStackLayout Spacing="14">

                    <!-- Nombre -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Nombre *" FontAttributes="Bold" FontSize="13" TextColor="#2C2C2A"/>
                        <Border BackgroundColor="#F5F5F0" StrokeThickness="0"
                                StrokeShape="RoundRectangle 10" Padding="12,0">
                            <Entry Text="{Binding NombreMasc, Mode=TwoWay}"
                                   Placeholder="Nombre de la mascota"
                                   PlaceholderColor="#B4B2A9" TextColor="#2C2C2A"
                                   HeightRequest="44" BackgroundColor="Transparent"/>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Tipo de animal: Perro / Gato / Otro -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Tipo de animal *" FontAttributes="Bold" FontSize="13" TextColor="#2C2C2A"/>
                        <Border BackgroundColor="#F5F5F0" StrokeThickness="0"
                                StrokeShape="RoundRectangle 10" Padding="12,0">
                            <Picker ItemsSource="{Binding TiposAnimal}"
                                    SelectedItem="{Binding TipoAnimal, Mode=TwoWay}"
                                    TextColor="#2C2C2A"
                                    HeightRequest="44"
                                    BackgroundColor="Transparent"/>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Especie libre — solo visible cuando TipoAnimal = Otro -->
                    <VerticalStackLayout Spacing="4" IsVisible="{Binding EspecieFieldVisible}">
                        <Label Text="Especie *" FontAttributes="Bold" FontSize="13" TextColor="#2C2C2A"/>
                        <Border BackgroundColor="#F5F5F0" StrokeThickness="0"
                                StrokeShape="RoundRectangle 10" Padding="12,0">
                            <Entry Text="{Binding EspeciePersonalizada, Mode=TwoWay}"
                                   Placeholder="Ej: Ave, Conejo, Reptil..."
                                   PlaceholderColor="#B4B2A9" TextColor="#2C2C2A"
                                   HeightRequest="44" BackgroundColor="Transparent"/>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Raza -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Raza" FontAttributes="Bold" FontSize="13" TextColor="#2C2C2A"/>
                        <Border BackgroundColor="#F5F5F0" StrokeThickness="0"
                                StrokeShape="RoundRectangle 10" Padding="12,0">
                            <Entry Text="{Binding Raza, Mode=TwoWay}"
                                   Placeholder="Ej: Golden Retriever, Siamés..."
                                   PlaceholderColor="#B4B2A9" TextColor="#2C2C2A"
                                   HeightRequest="44" BackgroundColor="Transparent"/>
                        </Border>
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </Border>

            <!-- ════════════════════════════════════════════════════════
                 SECCIÓN 2 — DATOS FÍSICOS
            ═══════════════════════════════════════════════════════════ -->
            <Label Text="DATOS FÍSICOS"
                   FontAttributes="Bold" FontSize="13" HorizontalOptions="Center" 
                   TextColor="White" Margin="4,0,700,0"/>

            <Border BackgroundColor="White"
                    StrokeThickness="0" WidthRequest="800"
                    StrokeShape="RoundRectangle 14"
                    Padding="16">
                <VerticalStackLayout Spacing="14">

                    <!-- Edad + Sexo en fila -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <VerticalStackLayout Grid.Column="0" Spacing="4">
                            <Label Text="Edad (años)" FontAttributes="Bold" FontSize="13" TextColor="#2C2C2A"/>
                            <Border BackgroundColor="#F5F5F0" StrokeThickness="0"
                                    StrokeShape="RoundRectangle 10" Padding="12,0">
                                <Entry Text="{Binding Edad, Mode=TwoWay}"
                                       Placeholder="0" Keyboard="Numeric"
                                       PlaceholderColor="#B4B2A9" TextColor="#2C2C2A"
                                       HeightRequest="44" BackgroundColor="Transparent"/>
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1" Spacing="4">
                            <Label Text="Sexo" FontAttributes="Bold" FontSize="13" TextColor="#2C2C2A"/>
                            <Border BackgroundColor="#F5F5F0" StrokeThickness="0"
                                    StrokeShape="RoundRectangle 10" Padding="12,0">
                                <Picker SelectedItem="{Binding Sexo, Mode=TwoWay}"
                                        TextColor="#2C2C2A" HeightRequest="44"
                                        BackgroundColor="Transparent">
                                    <Picker.Items>
                                        <x:String>Macho</x:String>
                                        <x:String>Hembra</x:String>
                                    </Picker.Items>
                                </Picker>
                            </Border>
                        </VerticalStackLayout>
                    </Grid>

                    <!-- Color -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Color / pelaje" FontAttributes="Bold" FontSize="13" TextColor="#2C2C2A"/>
                        <Border BackgroundColor="#F5F5F0" StrokeThickness="0"
                                StrokeShape="RoundRectangle 10" Padding="12,0">
                            <Entry Text="{Binding Color, Mode=TwoWay}"
                                   Placeholder="Describe su apariencia"
                                   PlaceholderColor="#B4B2A9" TextColor="#2C2C2A"
                                   HeightRequest="44" BackgroundColor="Transparent"/>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Tamaño — solo Perro -->
                    <VerticalStackLayout Spacing="4" IsVisible="{Binding SizeFieldVisible}">
                        <Label Text="Tamaño" FontAttributes="Bold" FontSize="13" TextColor="#2C2C2A"/>
                        <Border BackgroundColor="#F5F5F0" StrokeThickness="0"
                                StrokeShape="RoundRectangle 10" Padding="12,0">
                            <Picker ItemsSource="{Binding TamanosDisponibles}"
                                    SelectedItem="{Binding Tamano, Mode=TwoWay}"
                                    TextColor="#2C2C2A" HeightRequest="44"
                                    BackgroundColor="Transparent"/>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Tipo de pelo — solo Gato -->
                    <VerticalStackLayout Spacing="4" IsVisible="{Binding HairFieldVisible}">
                        <Label Text="Tipo de pelo" FontAttributes="Bold" FontSize="13" TextColor="#2C2C2A"/>
                        <Border BackgroundColor="#F5F5F0" StrokeThickness="0"
                                StrokeShape="RoundRectangle 10" Padding="12,0">
                            <Picker ItemsSource="{Binding TiposPeloDisponibles}"
                                    SelectedItem="{Binding TipoPelo, Mode=TwoWay}"
                                    TextColor="#2C2C2A" HeightRequest="44"
                                    BackgroundColor="Transparent"/>
                        </Border>
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </Border>

            <!-- ════════════════════════════════════════════════════════
                 SECCIÓN 3 — DATOS CLÍNICOS
            ═══════════════════════════════════════════════════════════ -->
            <Label Text="DATOS CLÍNICOS"
                   FontAttributes="Bold" FontSize="13" HorizontalOptions="Center"
                   TextColor="White" Margin="4,0,700,0"/>

            <Border BackgroundColor="White"
                    StrokeThickness="0" WidthRequest="800"
                    StrokeShape="RoundRectangle 14"
                    Padding="16">
                <VerticalStackLayout Spacing="14">

                    <Border BackgroundColor="#F5F5F0" StrokeThickness="0"
                            StrokeShape="RoundRectangle 12" Padding="14,12">
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Grid.Column="0" Spacing="2" VerticalOptions="Center">
                                <Label Text="¿Está vacunado?"
                                       FontAttributes="Bold" FontSize="13" TextColor="#2C2C2A"/>
                            </VerticalStackLayout>
                            <Switch Grid.Column="1"
                                    IsToggled="{Binding Vacunado, Mode=TwoWay}"
                                    OnColor="#2EBBB0" ThumbColor="White"
                                    VerticalOptions="Center"/>
                        </Grid>
                    </Border>

                    <VerticalStackLayout Spacing="4">
                        <Label Text="Notas adicionales" FontAttributes="Bold" FontSize="13" TextColor="#2C2C2A"/>
                        <Border BackgroundColor="#F5F5F0" StrokeThickness="0"
                                StrokeShape="RoundRectangle 10" Padding="12,8">
                            <Editor Text="{Binding Notas, Mode=TwoWay}"
                                    Placeholder="Alergias, condiciones especiales..."
                                    PlaceholderColor="#B4B2A9" TextColor="#2C2C2A"
                                    FontSize="14" HeightRequest="90"
                                    AutoSize="Disabled" BackgroundColor="Transparent"/>
                        </Border>
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </Border>

            <!-- ── Nota de obligatorios ───────────────────────────── -->
            <Label Text="* Campos obligatorios" HorizontalOptions="Center" FontAttributes="Bold"
                   FontSize="12" TextColor="White" Margin="4,0,700,0"/>

            <!-- ── Botones ─────────────────────────────────────────── -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,4,0,0" WidthRequest="800">
                <Button Grid.Column="0"
                        Text="💾 Guardar"
                        Command="{Binding GuardarCommand}"
                        BackgroundColor="#2EBBB0" TextColor="White"
                        FontAttributes="Bold" CornerRadius="12" HeightRequest="50"/>
                <Button Grid.Column="1"
                        Text="✕ Cancelar"
                        Command="{Binding CancelarCommand}"
                        BackgroundColor="#E8E8E3" TextColor="#2C2C2A"
                        FontAttributes="Bold" CornerRadius="12" HeightRequest="50"/>
            </Grid>

            <!-- ── Loading ─────────────────────────────────────────── -->
            <ActivityIndicator IsRunning="{Binding IsLoading}"
                               IsVisible="{Binding IsLoading}"
                               Color="#2EBBB0"
                               WidthRequest="40" HeightRequest="40"
                               HorizontalOptions="Center"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>