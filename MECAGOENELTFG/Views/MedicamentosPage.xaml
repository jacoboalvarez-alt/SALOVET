<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MECAGOENELTFG.Views.MedicamentosPage"
             xmlns:vm="clr-namespace:MECAGOENELTFG.ViewModels"
             Title="MedicamentosPage"
             BackgroundImageSource="fondo2.png"
             Shell.NavBarIsVisible="False">
    <ContentPage.BindingContext>
        <vm:MedicamentosViewModel />
    </ContentPage.BindingContext>
    <VerticalStackLayout>
        <Button Text="Volver"
          Command="{Binding IrADashboardCommand}"
          BackgroundColor="#2EBBB0"
          TextColor="White"
          HorizontalOptions="End"
          WidthRequest="140"
          VerticalOptions="End" Margin="0,5,10,0"/>

        <Label 
            Text="MEDICAMENTOS" FontSize="50" FontFamily="Milano" Margin=" 0,20,0,0" 
            VerticalOptions="Center"  TextColor="White" FontAttributes="Bold"
            HorizontalOptions="Center" />
    </VerticalStackLayout>
</ContentPage>