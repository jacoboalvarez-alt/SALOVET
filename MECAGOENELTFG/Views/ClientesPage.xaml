<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MECAGOENELTFG.ViewModels"
             x:Class="MECAGOENELTFG.Views.ClientesPage"
             x:DataType="vm:ClientesViewModel"
             xmlns:models="clr-namespace:MECAGOENELTFG.Models"
             Title="Gestion de Clientes"
             BackgroundImageSource="fondo2.png"
             Shell.NavBarIsVisible="False">
    <ContentPage.BindingContext>
        <vm:ClientesViewModel />
    </ContentPage.BindingContext>

    <Grid RowDefinitions="Auto,Auto,Auto,*" Padding="30,20,30,20">

        <!-- Fila superior: Título centrado + Volver a la derecha -->
        <Grid Grid.Row="0" ColumnDefinitions="150,*,150" Margin="0,10,0,10">

            <Label Grid.Column="1"
                   Text="Lista de Clientes"
                   FontSize="38"
                   TextColor="White"
                   FontFamily="Milano"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   VerticalOptions="Center" />
            <Button Grid.Column="2"
                    Text="← Volver"
                    Command="{Binding IrADashboardCommand}"
                    BackgroundColor="#1A9E94"
                    TextColor="White"
                    CornerRadius="10"
                    HeightRequest="40"
                    WidthRequest="130"
                    FontAttributes="Bold"
                    HorizontalOptions="End"
                    VerticalOptions="Center" />
        </Grid>

        <!-- Separador decorativo -->
        <BoxView Grid.Row="1"
                 HeightRequest="1" WidthRequest="270"
                 BackgroundColor="#FFFFFF40"
                 Margin="0,0,0,15" />

        <!-- Barra de acciones -->
        <Grid Grid.Row="2" ColumnDefinitions="*,Auto" Margin="0,0,0,12">
            <HorizontalStackLayout Grid.Column="1" Spacing="8">
                <Button Text="➕  Agregar Cliente"
                        Command="{Binding AgregarClienteCommand}"
                        BackgroundColor="#4CAF50"
                        TextColor="White"
                        CornerRadius="10"
                        HeightRequest="40"
                        FontAttributes="Bold"
                        Padding="16,0" />
                <Button Text="🔄  Refrescar"
                        Command="{Binding CargarClientesCommand}"
                        BackgroundColor="#1A9E94"
                        TextColor="White"
                        CornerRadius="10"
                        HeightRequest="40"
                        FontAttributes="Bold"
                        Padding="16,0" />
            </HorizontalStackLayout>
        </Grid>

        <!-- Tabla con borde y sombra -->
        <Border Grid.Row="3" WidthRequest="1250"
                BackgroundColor="White"
                StrokeShape="RoundRectangle 14"
                Stroke="#FFFFFF30"
                Padding="0">

            <Grid RowDefinitions="Auto,*">

                <!-- Encabezado de tabla -->
                <Grid Grid.Row="0"
                      ColumnDefinitions="45,120,130,55,*,100,150"
                      BackgroundColor="#2EBBB0"
                      Padding="12,12">
                    <Label Grid.Column="0" Text="ID"       TextColor="White" FontAttributes="Bold" FontSize="13" FontFamily="Nunito" VerticalOptions="Center"/>
                    <Label Grid.Column="1" Text="Nombre"   TextColor="White" FontAttributes="Bold" FontSize="13" FontFamily="Nunito" VerticalOptions="Center"/>
                    <Label Grid.Column="2" Text="Apellido" TextColor="White" FontAttributes="Bold" FontSize="13" FontFamily="Nunito" VerticalOptions="Center"/>
                    <Label Grid.Column="3" Text="Edad"     TextColor="White" FontAttributes="Bold" FontSize="13" FontFamily="Nunito" VerticalOptions="Center"/>
                    <Label Grid.Column="4" Text="Correo"   TextColor="White" FontAttributes="Bold" FontSize="13" FontFamily="Nunito" VerticalOptions="Center"/>
                    <Label Grid.Column="5" Text="Teléfono" TextColor="White" FontAttributes="Bold" FontSize="13" FontFamily="Nunito" VerticalOptions="Center"/>
                    <Label Grid.Column="6" Text="Acciones" TextColor="White" FontAttributes="Bold" FontSize="13" FontFamily="Nunito" HorizontalOptions="Center" VerticalOptions="Center"/>
                </Grid>

                <!-- Indicador de carga -->
                <ActivityIndicator Grid.Row="1"
                                   IsRunning="{Binding IsLoading}"
                                   IsVisible="{Binding IsLoading}"
                                   Color="#2EBBB0"
                                   WidthRequest="50"
                                   HeightRequest="50"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />

                <!-- Filas de datos -->
                <ScrollView Grid.Row="1">
                    <CollectionView ItemsSource="{Binding Clientes}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:Cliente">
                                <Grid ColumnDefinitions="45,120,130,55,*,120,150"
                                      Padding="12,8"
                                      Margin="0,0,0,0">
                                    <Grid.Triggers>
                                        <DataTrigger TargetType="Grid" Binding="{Binding IdCliente}" Value="0">
                                            <Setter Property="BackgroundColor" Value="#F9FFFE" />
                                        </DataTrigger>
                                    </Grid.Triggers>
                                    <Grid.BackgroundColor>#F9FFFE</Grid.BackgroundColor>

                                    <!-- Separador inferior por fila -->
                                    <BoxView Grid.ColumnSpan="7"
                                             HeightRequest="1"
                                             BackgroundColor="#E0F5F3"
                                             VerticalOptions="End" />

                                    <Label Grid.Column="0" Text="{Binding IdCliente}" TextColor="#444" FontSize="14" FontFamily="Nunito" VerticalOptions="Center"/>
                                    <Label Grid.Column="1" Text="{Binding NombreCli}" TextColor="#222" FontSize="14" FontFamily="Nunito" VerticalOptions="Center" FontAttributes="Bold"/>
                                    <Label Grid.Column="2" Text="{Binding ApeCli}"    TextColor="#444" FontSize="14" FontFamily="Nunito" VerticalOptions="Center"/>
                                    <Label Grid.Column="3" Text="{Binding Edad}"      TextColor="#444" FontSize="14" FontFamily="Nunito" VerticalOptions="Center"/>
                                    <Label Grid.Column="4" Text="{Binding Correo}"    TextColor="#555" FontSize="13" FontFamily="Nunito" LineBreakMode="TailTruncation" VerticalOptions="Center"/>
                                    <Label Grid.Column="5" Text="{Binding Tel}"       TextColor="#444" FontSize="14" FontFamily="Nunito" VerticalOptions="Center"/>

                                    <HorizontalStackLayout Grid.Column="6"
                                                           Spacing="5"
                                                           HorizontalOptions="Center"
                                                           VerticalOptions="Center">
                                        <Button Text="🐾"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ClientesViewModel}}, Path=VerMascotasCommand}"
                                                CommandParameter="{Binding .}"
                                                BackgroundColor="#FF9800"
                                                TextColor="White"
                                                CornerRadius="8"
                                                WidthRequest="36"
                                                HeightRequest="32"
                                                Padding="0"
                                                FontSize="14" />
                                        <Button Text="✏️"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ClientesViewModel}}, Path=EditarClienteCommand}"
                                                CommandParameter="{Binding .}"
                                                BackgroundColor="#2196F3"
                                                TextColor="White"
                                                CornerRadius="8"
                                                WidthRequest="36"
                                                HeightRequest="32"
                                                Padding="0"
                                                FontSize="14" />
                                        <Button Text="🗑️"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ClientesViewModel}}, Path=EliminarClienteCommand}"
                                                CommandParameter="{Binding .}"
                                                BackgroundColor="#F44336"
                                                TextColor="White"
                                                CornerRadius="8"
                                                WidthRequest="36"
                                                HeightRequest="32"
                                                Padding="0"
                                                FontSize="14" />
                                    </HorizontalStackLayout>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </ScrollView>
            </Grid>
        </Border>

    </Grid>
</ContentPage>