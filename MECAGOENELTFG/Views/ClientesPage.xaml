<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MECAGOENELTFG.ViewModels"
             x:Class="MECAGOENELTFG.Views.ClientesPage"
             x:DataType="vm:ClientesViewModel"
             xmlns:models="clr-namespace:MECAGOENELTFG.Models"
             Title="Gestion de Clientes"
             BackgroundImageSource="fondo2.png"
             Shell.NavBarIsVisible="False">
    <ContentPage.BindingContext>
        <vm:ClientesViewModel />
    </ContentPage.BindingContext>

    <Grid RowDefinitions="Auto,Auto,*" Padding="10">

        <!-- Título -->
        <Label Grid.Row="0"
           Text="Lista de Clientes"
           FontSize="50"
           TextColor="White"
           FontFamily="Notedry"
           FontAttributes="Bold"
           Margin="0,20,0,80"
           HorizontalOptions="Center" />

        <!-- Encabezado con botones -->
        <HorizontalStackLayout Grid.Row="1" 
                           Spacing="10" 
                           Padding="10"
                           Margin="0,0,0,10">
            <Button Text="➕ Agregar Cliente"
                Command="{Binding AgregarClienteCommand}"
                BackgroundColor="#4CAF50"
                TextColor="White" />
            <Button Text="🔄 Refrescar"
                Command="{Binding CargarClientesCommand}"
                BackgroundColor="#2196F3"
                TextColor="White" />
        </HorizontalStackLayout>

        <!-- Indicador de carga -->
        <ActivityIndicator Grid.Row="1"
                       IsRunning="{Binding IsLoading}"
                       IsVisible="{Binding IsLoading}"
                       Color="#2196F3"
                       WidthRequest="50"
                       HeightRequest="50"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />

        <!-- Tabla de Clientes -->
        <ScrollView Grid.Row="2">
            <!-- ← CORREGIDO: era Row="3" -->
            <VerticalStackLayout Spacing="0">

                <!-- Encabezado de la tabla -->
                <Grid ColumnDefinitions="35,100,110,45,*,95,140"
                  BackgroundColor="#E0E0E0"
                  Padding="8,10"
                  Margin="0,0,0,2">
                    <Label Grid.Column="0" Text="ID" FontAttributes="Bold" FontSize="13"  FontFamily="Nunito"/>
                    <Label Grid.Column="1" Text="Nombre" FontAttributes="Bold" FontSize="13" FontFamily="Nunito" />
                    <Label Grid.Column="2" Text="Apellido" FontAttributes="Bold" FontSize="13"  FontFamily="Nunito"/>
                    <Label Grid.Column="3" Text="Edad" FontAttributes="Bold" FontSize="13"  FontFamily="Nunito" />
                    <Label Grid.Column="4" Text="Correo" FontAttributes="Bold" FontSize="13"  FontFamily="Nunito" />
                    <Label Grid.Column="5" Text="Teléfono" FontAttributes="Bold" FontSize="13" FontFamily="Nunito" />
                    <Label Grid.Column="6" Text="Acciones" FontAttributes="Bold" FontSize="13" HorizontalOptions="Center"  FontFamily="Nunito"/>
                </Grid>

                <!-- Filas de datos -->
                <CollectionView ItemsSource="{Binding Clientes}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:Cliente">
                            <Grid ColumnDefinitions="35,100,110,45,*,95,140"
                              BackgroundColor="White"
                              Padding="8,6"
                              Margin="0,0,0,1">

                                <Label Grid.Column="0"
                                   Text="{Binding IdCliente}"
                                   TextColor="Black"
                                   FontSize="16"  FontFamily="Nunito"
                                   VerticalOptions="Center" />

                                <Label Grid.Column="1"
                                   Text="{Binding NombreCli}"
                                   TextColor="Black"
                                   FontSize="16"  FontFamily="Nunito"
                                   VerticalOptions="Center" />

                                <Label Grid.Column="2"
                                   Text="{Binding ApeCli}"
                                   TextColor="Black"
                                   FontSize="16"  FontFamily="Nunito"
                                   VerticalOptions="Center" />

                                <Label Grid.Column="3"
                                   Text="{Binding Edad}"
                                   TextColor="Black"
                                   FontSize="16"  FontFamily="Nunito"
                                   VerticalOptions="Center" />

                                <Label Grid.Column="4"
                                   Text="{Binding Correo}"
                                   TextColor="Black"
                                   FontSize="16"  FontFamily="Nunito"
                                   LineBreakMode="TailTruncation"
                                   VerticalOptions="Center" />

                                <Label Grid.Column="5"
                                   Text="{Binding Tel}"
                                   TextColor="Black"
                                   FontSize="16"   FontFamily="Nunito"
                                   VerticalOptions="Center" />

                                <HorizontalStackLayout Grid.Column="6"
                                                   Spacing="4"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center">
                                    <Button Text="🐾"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ClientesViewModel}}, Path=VerMascotasCommand}"
                                        CommandParameter="{Binding .}"
                                        BackgroundColor="#FF9800"
                                        TextColor="White"
                                        WidthRequest="38"
                                        HeightRequest="32"
                                        Padding="0"
                                        FontSize="14" />
                                    <Button Text="✏️"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ClientesViewModel}}, Path=EditarClienteCommand}"
                                        CommandParameter="{Binding .}"
                                        BackgroundColor="#2196F3"
                                        TextColor="White"
                                        WidthRequest="38"
                                        HeightRequest="32"
                                        Padding="0"
                                        FontSize="14" />
                                    <Button Text="🗑️"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ClientesViewModel}}, Path=EliminarClienteCommand}"
                                        CommandParameter="{Binding .}"
                                        BackgroundColor="#F44336"
                                        TextColor="White"
                                        WidthRequest="38"
                                        HeightRequest="32"
                                        Padding="0"
                                        FontSize="14" />
                                </HorizontalStackLayout>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Label Text="No hay clientes registrados"
                   IsVisible="{Binding Clientes.Count, Converter={StaticResource IsZeroConverter}}"
                   HorizontalOptions="Center"
                   Margin="0,50,0,0"
                   FontSize="18"
                   TextColor="Gray" />

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>