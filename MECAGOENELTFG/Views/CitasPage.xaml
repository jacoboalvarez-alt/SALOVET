<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MECAGOENELTFG.Views.CitasPage"
             xmlns:vm="clr-namespace:MECAGOENELTFG.ViewModels"
             Shell.NavBarIsVisible="False"
             BackgroundImageSource="fondo2.png"
             Title="CitasPage">
    <ContentPage.BindingContext>
        <vm:CitasViewModel />
    </ContentPage.BindingContext>
    
    <VerticalStackLayout>
        <Button Text="Volver"
         Command="{Binding IrADashboardCommand}"
         BackgroundColor="#2EBBB0"
         TextColor="White"
         HorizontalOptions="End"
         WidthRequest="140"
         VerticalOptions="End" Margin="0,5,10,0"/>
        <Label 
            Text="CITAS" FontSize="55" HorizontalOptions="Center" VerticalOptions="Center"
            FontFamily="Milano" Margin="0,20,0,0" FontAttributes="Bold" TextColor="White"
            />


    </VerticalStackLayout>
</ContentPage>