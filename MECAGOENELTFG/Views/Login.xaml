<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MECAGOENELTFG.ViewModels"
             x:Class="MECAGOENELTFG.Views.Login"
             Shell.NavBarIsVisible="False"
             IconImageSource="salovet_logo.ico"
             Title="Login"
             BackgroundImageSource="fondo1.png">

    <ContentPage.BindingContext>
        <vm:LoginViewModel/>
    </ContentPage.BindingContext>

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="25" VerticalOptions="Center">
            <!--LOGO-->
            <Image Source="salovet_logo1.png" HeightRequest="350" Aspect="AspectFit" HorizontalOptions="Center" />

            <!--ESPACIO PARA FORMULARIO-->
            <Border BackgroundColor="White" StrokeShape="RoundRectangle 16" Stroke="Transparent" Padding="24" WidthRequest="600">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,4" Radius="12" Opacity="0.1"></Shadow>
                </Border.Shadow>

                <VerticalStackLayout Spacing="16">
                    <!--LABEL DE INICIO DE SESION-->
                    <Label Text="Iniciar Sesion" FontSize="22" FontAttributes="Bold" TextColor="Black" HorizontalOptions="Center" VerticalOptions="Center" />

                    <!-- USUARIO-->
                    <VerticalStackLayout Padding="4">
                        <Label Text="Usuario" FontSize="22" TextColor="Black" HorizontalOptions="Start" />
                        <Entry Placeholder="Introduce tu usuario: Ex: usario123" PlaceholderColor="#AAAAAA" 
                           TextColor="Black" BackgroundColor="#F5F7FA"
                           HeightRequest="45" WidthRequest="490" MinimumWidthRequest="250" MaximumWidthRequest="600" Text="{Binding Username}"  
                       />
                    </VerticalStackLayout>

                    <!--CONTRASENA-->
                    <VerticalStackLayout Padding="4">
                        <Label Text="Contraseña" FontSize="22" TextColor="Black" />
                        <Entry Placeholder="Introduce tu Contraseña: " PlaceholderColor="#AAAAAA" IsPassword="True"
                               TextColor="Black" BackgroundColor="#F5F7FA"  HeightRequest="45" Text="{Binding Password}" WidthRequest="490" 
                               MinimumWidthRequest="250" MaximumWidthRequest="600"
                               />
                    </VerticalStackLayout>

                    <!--MENSAJE PARA ERRORES-->
                    <Label TextColor="#E53935" FontSize="15" HorizontalOptions="Center" 
                           IsVisible="{Binding MensajeError, Converter={x:StaticResource StringToBoolConverter }}" Text="{Binding MensajeError}"/>

                    <!--BOTON DE INICIO DE SESION-->
                    <Button Text="Entrar" Command="{Binding LoginCommand}" BackgroundColor="#2EBBB0" TextColor="White"
                            FontAttributes="Bold"     CornerRadius="10"  HeightRequest="50" 
                            IsEnabled="{Binding IsLoading, Converter={x:StaticResource InvertedBoolConverter}}"
                            />
                    <!--LOADING-->
                    <ActivityIndicator IsRunning="{Binding IsLoading}" IsVisible="{Binding IsLoading}" Color="#1A3C6E"  HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Border>
            <!--<Label Text="Usuario:vet_roberto Pass:vetpass001" FontSize="22" TextColor="Black" />-->
            <!-- REGISTRO -->
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="4">
                <Label Text="¿No tienes cuenta?"
                       TextColor="#555555"
                       FontSize="14"
                       VerticalOptions="Center" />
                <Label Text="Regístrate"
                       TextColor="#1A3C6E"
                       FontSize="14"
                       FontAttributes="Bold"
                       VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding IrARegistroCommand}" />
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>